# Stage 1: Build the Next.js applications
FROM node:20-alpine AS builder

WORKDIR /app

# Install system utilities needed for building
RUN apk add --no-cache rsync

# Copy configuration and workspaces
COPY version.json ./
COPY shared ./shared
COPY apps/customer-app ./apps/customer-app
COPY apps/vendor-app ./apps/vendor-app
COPY apps/delivery-app ./apps/delivery-app
COPY apps/admin-app ./apps/admin-app
COPY apps/sabjiwala-web ./apps/sabjiwala-web

# Build the shared library first
RUN cd shared && npm install && npm run build

# Setup and build the unified web application
RUN cd apps/sabjiwala-web && \
    npm install && \
    # Replace symlink with physical copy of shared package to satisfy Turbopack
    rm -rf node_modules/@sabjiwala/shared && \
    mkdir -p node_modules/@sabjiwala/shared && \
    cp -r ../../shared/dist node_modules/@sabjiwala/shared/ && \
    cp -r ../../shared/src node_modules/@sabjiwala/shared/ && \
    cp ../../shared/package.json node_modules/@sabjiwala/shared/ && \
    cp ../../shared/tsconfig.json node_modules/@sabjiwala/shared/ && \
    # Install axios in web portal to satisfy shared package
    npm install axios && \
    # Copy dashboards
    cp ../customer-app/src/app/page.tsx src/app/page.tsx && \
    cp ../vendor-app/src/app/page.tsx src/app/vendor/page.tsx && \
    cp ../delivery-app/src/app/page.tsx src/app/delivery/page.tsx && \
    cp ../admin-app/src/app/page.tsx src/app/admin/page.tsx && \
    # Build Next.js
    npm run build

# Stage 2: Serve using Nginx
FROM nginx:stable-alpine

COPY --from=builder /app/apps/sabjiwala-web/out /usr/share/nginx/html
COPY ./infrastructure/nginx/nginx.conf /etc/nginx/nginx.conf

EXPOSE 80 443

CMD ["nginx", "-g", "daemon off;"]
