# Stage 1: Build the Next.js applications
FROM --platform=$BUILDPLATFORM node:24-alpine AS builder

WORKDIR /app

# Install system utilities needed for building
RUN apk add --no-cache rsync

# Copy configuration and workspaces
COPY version.json ./
COPY shared ./shared
COPY apps/customer-app ./apps/customer-app
COPY apps/vendor-app ./apps/vendor-app
COPY apps/delivery-app ./apps/delivery-app
COPY apps/admin-app ./apps/admin-app
COPY apps/agent-app ./apps/agent-app
COPY apps/sbjiwala-web ./apps/sbjiwala-web
COPY tmp ./tmp

# Build the shared library first
RUN cd shared && npm install && npm run build

# Setup and build the unified web application
RUN cd apps/sbjiwala-web && \
    npm install && \
    # Replace symlink with physical copy of shared package to satisfy Turbopack
    rm -rf node_modules/@sbjiwala/shared && \
    mkdir -p node_modules/@sbjiwala/shared && \
    cp -r ../../shared/dist node_modules/@sbjiwala/shared/ && \
    cp -r ../../shared/src node_modules/@sbjiwala/shared/ && \
    cp ../../shared/package.json node_modules/@sbjiwala/shared/ && \
    cp ../../shared/tsconfig.json node_modules/@sbjiwala/shared/ && \
    # Build Next.js
    npm run build

# Stage 2: Serve using Nginx
FROM nginx:stable-alpine

COPY --from=builder /app/apps/sbjiwala-web/out /usr/share/nginx/html
COPY ./infrastructure/nginx/nginx.conf /etc/nginx/nginx.conf

EXPOSE 80 443

CMD ["nginx", "-g", "daemon off;"]
