        "axios": "^1.16.1",
        "firebase": "^12.15.0",
        "leaflet": "^1.9.4",
        "lucide-react": "^1.17.0",
        "next": "16.2.6",
        "react": "19.2.6",
        "react-dom": "19.2.6",
        "react-hook-form": "^7.76.1",
