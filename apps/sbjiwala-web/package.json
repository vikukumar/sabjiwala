{
  "name": "sbjiwala-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "prebuild": "node ../../tmp/fix_node_modules.js && node sync-subapps.js && node -e \"const fs=require('fs'),path=require('path'); if(!process.env.NEXT_PUBLIC_APP_VERSION){const rv=fs.readFileSync('../../version.json','utf8'); ['src/app/version.json','src/app/admin/version.json','src/app/vendor/version.json','src/app/delivery/version.json'].forEach(p=>{fs.mkdirSync(path.dirname(p),{recursive:true});fs.writeFileSync(p,rv);})}\"",
    "predev": "node ../../tmp/fix_node_modules.js && node sync-subapps.js && node -e \"const fs=require('fs'),path=require('path'); if(!process.env.NEXT_PUBLIC_APP_VERSION){const rv=fs.readFileSync('../../version.json','utf8'); ['src/app/version.json','src/app/admin/version.json','src/app/vendor/version.json','src/app/delivery/version.json'].forEach(p=>{fs.mkdirSync(path.dirname(p),{recursive:true});fs.writeFileSync(p,rv);})}\""
  },
  "dependencies": {
    "@capacitor/local-notifications": "^8.2.0",
    "@capacitor/push-notifications": "^8.1.1",
    "@sbjiwala/shared": "file:../../shared",
    "@tanstack/react-query": "^5.100.14",
    "axios": "^1.16.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.17.0",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-hook-form": "^7.76.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^10",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^6"
  }
}
