{
    "name":  "delivery-app",
    "version":  "0.1.0",
    "private":  true,
    "scripts":  {
                    "dev":  "next dev",
                    "build":  "next build",
                    "start":  "next start",
                    "lint":  "eslint",
                    "cap:sync":  "npx cap sync",
                    "cap:build":  "npm run build \u0026\u0026 npx cap copy",
                    "cap:open":  "npx cap open android",
                    "cap:release":  "npm run build \u0026\u0026 npx cap copy android \u0026\u0026 cd android \u0026\u0026 gradlew.bat assembleRelease",
                    "prebuild":  "node ../../tmp/fix_node_modules.js \u0026\u0026 node -e \"const fs=require(\u0027fs\u0027),path=require(\u0027path\u0027); const vj=path.resolve(\u0027src/app/version.json\u0027); if(!process.env.NEXT_PUBLIC_APP_VERSION){const rv=fs.readFileSync(\u0027../../version.json\u0027,\u0027utf8\u0027); fs.mkdirSync(path.dirname(vj),{recursive:true}); fs.writeFileSync(vj,rv);}\"",
                    "predev":  "node ../../tmp/fix_node_modules.js \u0026\u0026 node -e \"const fs=require(\u0027fs\u0027),path=require(\u0027path\u0027); const vj=path.resolve(\u0027src/app/version.json\u0027); if(!process.env.NEXT_PUBLIC_APP_VERSION){const rv=fs.readFileSync(\u0027../../version.json\u0027,\u0027utf8\u0027); fs.mkdirSync(path.dirname(vj),{recursive:true}); fs.writeFileSync(vj,rv);}\""
                },
