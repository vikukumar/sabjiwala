{
  "appId": "in.sbjiwala.admin",
  "appName": "Sbjiwala Admin",
  "webDir": "out",
  "server": {
    "cleartext": false,
    "androidScheme": "https"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "launchAutoHide": true,
      "backgroundColor": "#090d10",
      "androidSplashResourceName": "splash",
      "showSpinner": false
    },
    "StatusBar": {
      "style": "Dark",
      "backgroundColor": "#059669"
    },
    "Geolocation": {
      "permissions": {
        "location": [
          "coarse",
          "fine"
        ]
      }
    }
  }
}