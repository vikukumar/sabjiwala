{
  "appId": "in.sbjiwala.customer",
  "appName": "Sbjiwala",
  "webDir": "out",
  "server": {
    "cleartext": false,
    "androidScheme": "https",
    "allowNavigation": [
      "*.sbjiwala.qzz.io",
      "sbjiwala.qzz.io"
    ]
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "launchAutoHide": true,
      "backgroundColor": "#090d10",
      "androidSplashResourceName": "splash",
      "showSpinner": false
    },
    "CapacitorCookies": {
      "enabled": true
    },
    "Geolocation": {
      "permissions": {
        "location": [
          "coarse",
          "fine"
        ]
      }
    }
  }
}