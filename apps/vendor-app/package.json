{
  "name": "vendor-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "cap:sync": "npx cap sync",
    "cap:build": "npm run build && npx cap copy",
    "cap:open": "npx cap open android",
    "cap:release": "npm run build && npx cap copy android && cd android && gradlew.bat assembleRelease",
    "prebuild": "node ../../tmp/fix_node_modules.js && node -e \"const fs = require('fs'); fs.copyFileSync('../../version.json', 'src/app/version.json');\"",
    "predev": "node ../../tmp/fix_node_modules.js && node -e \"const fs = require('fs'); fs.copyFileSync('../../version.json', 'src/app/version.json');\""
  },
  "dependencies": {
