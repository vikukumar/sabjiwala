{
  "appId": "in.sbjiwala.vendor",
  "appName": "Sbjiwala Vendor",
  "webDir": "out",
  "server": {
    "url": "https://vendor.sbjiwala.in",
    "cleartext": false,
    "androidScheme": "https",
    "allowNavigation": [
      "*.sbjiwala.in",
      "sbjiwala.in"
    ]
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "launchAutoHide": true,
      "backgroundColor": "#090d10",
      "androidSplashResourceName": "splash",
      "showSpinner": false
    },
    "Geolocation": {
      "permissions": {
        "location": ["coarse", "fine"]
      }
    }
  }
}