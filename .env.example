# ============================================================
# SabjiWala.in Environment Configuration
# Copy this to .env and fill in your values
# ============================================================

# ---- Application ----
APP_NAME=SabjiWala
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost
APP_SECRET_KEY=change-this-to-a-random-64-char-string
APP_ALLOWED_HOSTS=localhost,127.0.0.1

# ---- PostgreSQL ----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=sabjiwala
POSTGRES_USER=sabjiwala
POSTGRES_PASSWORD=change-this-strong-password
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-this-redis-password
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/0
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/1
CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/2

# ---- JWT ----
JWT_SECRET_KEY=change-this-to-a-different-random-64-char-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- Storage ----
STORAGE_ROOT=/app/storage
STORAGE_MAX_UPLOAD_SIZE_MB=50
STORAGE_ENCRYPTION_KEY=change-this-to-a-32-byte-hex-key-64-chars

# ---- Email (SMTP) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=SabjiWala
SMTP_FROM_EMAIL=noreply@sabjiwala.in
SMTP_USE_TLS=true

# ---- SMS (MSG91) ----
SMS_PROVIDER=msg91
MSG91_AUTH_KEY=your-msg91-auth-key
MSG91_SENDER_ID=SABJWL
MSG91_TEMPLATE_ID=your-template-id

# ---- Push Notifications (Web Push VAPID) ----
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:admin@sabjiwala.in

# ---- Google OAuth2 ----
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost/api/v1/auth/google/callback

# ---- Razorpay ----
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# ---- PhonePe ----
PHONEPE_MERCHANT_ID=your-phonepe-merchant-id
PHONEPE_SALT_KEY=your-phonepe-salt-key
PHONEPE_SALT_INDEX=1
PHONEPE_ENV=UAT

# ---- WhatsApp (Webhook) ----
WHATSAPP_API_URL=https://your-whatsapp-api-endpoint
WHATSAPP_API_KEY=your-whatsapp-api-key

# ---- OpenStreetMap / OSRM ----
NOMINATIM_URL=https://nominatim.openstreetmap.org
OSRM_URL=http://router.project-osrm.org
NOMINATIM_USER_AGENT=SabjiWala/1.0

# ---- Rate Limiting ----
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_UPLOAD=5/minute

# ---- CORS ----
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003

# ---- Frontend Ports (Dev) ----
CUSTOMER_APP_PORT=3000
VENDOR_APP_PORT=3001
DELIVERY_APP_PORT=3002
ADMIN_APP_PORT=3003
BACKEND_PORT=8000

# ---- Multi-Domain Nginx Routing (Production Complete Container) ----
CUSTOMER_DOMAIN=customer.sabjiwala.local
VENDOR_DOMAIN=vendor.sabjiwala.local
DELIVERY_DOMAIN=delivery.sabjiwala.local
ADMIN_DOMAIN=admin.sabjiwala.local
API_DOMAIN=api.sabjiwala.local
BACKEND_URL=http://127.0.0.1:8000

# ---- Super Admin (Initial Setup) ----
INITIAL_ADMIN_EMAIL=admin@sabjiwala.in
INITIAL_ADMIN_PASSWORD=change-this-immediately

# ---- Geo Blocking ----
GEO_BLOCK_ENABLED=false
GEO_ALLOWED_COUNTRIES=IN

# ---- Logging ----
LOG_LEVEL=INFO
LOG_FORMAT=json
