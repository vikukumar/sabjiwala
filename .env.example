# ============================================================
# Sbjiwala Environment Configuration
# Copy this to .env and fill in your values
# ============================================================

# ---- Application ----
APP_NAME=Sbjiwala
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost
APP_SECRET_KEY=change-this-to-a-random-64-char-string
APP_ALLOWED_HOSTS=localhost,127.0.0.1

# ---- PostgreSQL ----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=sbjiwala
POSTGRES_USER=sbjiwala
POSTGRES_PASSWORD=change-this-strong-password
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
DB_ECHO=false

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-this-redis-password
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/0
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/1
CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/2

# ---- JWT ----
JWT_SECRET_KEY=change-this-to-a-different-random-64-char-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- Storage ----
STORAGE_ROOT=/app/storage
STORAGE_MAX_UPLOAD_SIZE_MB=50
STORAGE_ENCRYPTION_KEY=change-this-to-a-32-byte-hex-key-64-chars

# ---- Email (SMTP) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=Sbjiwala
SMTP_FROM_EMAIL=noreply@sbjiwala.qzz.io
SMTP_USE_TLS=true

# ---- SMS (MSG91) ----
SMS_PROVIDER=msg91
MSG91_AUTH_KEY=your-msg91-auth-key
MSG91_SENDER_ID=SABJWL
MSG91_TEMPLATE_ID=your-template-id

# ---- Push Notifications (Web Push VAPID) ----
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:admin@sbjiwala.qzz.io

# ---- Google OAuth2 ----
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost/api/v1/auth/google/callback

# ---- Razorpay ----
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# ---- PhonePe ----
PHONEPE_MERCHANT_ID=your-phonepe-merchant-id
PHONEPE_SALT_KEY=your-phonepe-salt-key
PHONEPE_SALT_INDEX=1
PHONEPE_ENV=UAT

# ---- WhatsApp (Webhook) ----
WHATSAPP_API_URL=https://your-whatsapp-api-endpoint
WHATSAPP_API_KEY=your-whatsapp-api-key

# ---- OpenStreetMap / OSRM ----
NOMINATIM_URL=https://nominatim.openstreetmap.org
OSRM_URL=http://router.project-osrm.org
NOMINATIM_USER_AGENT=Sbjiwala/1.0

# ---- Rate Limiting ----
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_UPLOAD=5/minute

# ---- CORS ----
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003

# ---- Frontend Ports (Dev) ----
CUSTOMER_APP_PORT=3000
VENDOR_APP_PORT=3001
DELIVERY_APP_PORT=3002
ADMIN_APP_PORT=3003
BACKEND_PORT=8000

# ---- Multi-Domain Nginx Routing (Production Complete Container) ----
CUSTOMER_DOMAIN=customer.sbjiwala.local
VENDOR_DOMAIN=vendor.sbjiwala.local
DELIVERY_DOMAIN=delivery.sbjiwala.local
ADMIN_DOMAIN=admin.sbjiwala.local
API_DOMAIN=api.sbjiwala.local
BACKEND_URL=http://127.0.0.1:8000

# ---- Super Admin (Initial Setup) ----
INITIAL_ADMIN_EMAIL=admin@sbjiwala.qzz.io
INITIAL_ADMIN_PASSWORD=change-this-immediately

# ---- Geo Blocking ----
GEO_BLOCK_ENABLED=false
GEO_ALLOWED_COUNTRIES=IN

# ---- Firebase (Frontend — Next.js public vars) ----
# Get these from: Firebase Console → Project Settings → General → Your apps
# NEVER hardcode these values in source files — set them in .env.local (gitignored)
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=1:your-sender-id:web:your-app-id

# ---- Firebase Admin SDK (Backend — server-side only, NEVER frontend) ----
# Option A (recommended for production): Set GOOGLE_APPLICATION_CREDENTIALS to the
#   path of your service account JSON file on the server (NOT inside the repo).
#   e.g. GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/firebase-sa.json
#
# Option B (for Docker/CI): Inline the service account as a base64-encoded env var:
#   Run: base64 -i your-service-account.json | tr -d '\n'
#   Then set: FIREBASE_SERVICE_ACCOUNT_B64=<output>
#
# The backend will try Option B first, then Option A (GOOGLE_APPLICATION_CREDENTIALS).
# NEVER commit the JSON file itself to the repository.
FIREBASE_SERVICE_ACCOUNT_B64=
GOOGLE_APPLICATION_CREDENTIALS=

# ---- Logging ----
LOG_LEVEL=INFO
LOG_FORMAT=json
